{
  "services": {
    "frontend": {
      "root": "frontend/"
    },
    "backend": {
      "root": "backend/",
      "entrypoint": "main:app",
      "routes": [
        {
          "src": "/api/?(.*)",
          "transforms": [
            {
              "type": "request.path",
              "op": "set",
              "args": "/$1"
            }
          ]
        }
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)?",
      "destination": { "service": "backend" }
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": { "pre": "api." } }],
      "destination": { "service": "backend" }
    },
    {
      "source": "/(.*)",
      "destination": { "service": "frontend" }
    }
  ]
}
