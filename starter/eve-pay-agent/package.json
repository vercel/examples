  "dependencies": {
    "@solana/addresses": "6.9.0",
    "ai": "7.0.22",
    "eve": "0.22.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "prettier": "2.8.8",
    "typescript": "5.9.3"
