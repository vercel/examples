{
  "name": "eve-pay-agent",
  "version": "0.1.0",
  "description": "Approval-gated eve agent that buys sandbox API access with Pay.sh",
  "repository": "https://github.com/vercel/examples.git",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "eve build",
